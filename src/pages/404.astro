---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="页面不存在" description="404">
  <div class="container-prose py-24 text-center">
    <p class="text-7xl font-bold text-[var(--accent)]">404</p>
    <h1 class="mt-4 text-2xl font-semibold">页面不存在</h1>
    <p class="mt-2 text-[var(--fg-muted)]">你要找的内容可能已经被移动或删除。</p>
    <a href="/" class="mt-8 inline-block rounded-md bg-[var(--accent)] px-5 py-2 text-sm font-medium text-[var(--accent-contrast)] hover:bg-[var(--accent-hover)] transition-colors">返回首页</a>
  </div>
</Layout>
