---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import PostExplorer from "@/components/PostExplorer.astro";
import Footer from "@/components/Footer.astro";
import Pagination from "@/components/Pagination.astro";
import {
  getCategoryItems,
  getPostsByTaxonomy,
  getSeriesItems,
  getTypeItems,
} from "@/utils/taxonomy";
import config from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const seriesItems = getSeriesItems(posts);

  return seriesItems.flatMap(series => {
    const seriesPosts = getPostsByTaxonomy(posts, "series", series.slug);

    return paginate(seriesPosts, {
      params: { series: series.slug },
      props: { seriesName: series.name },
      pageSize: config.posts.perPage,
    });
  });
}

const { page, seriesName } = Astro.props;
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const categories = getCategoryItems(allPosts);
const series = getSeriesItems(allPosts);
const types = getTypeItems(allPosts);
---

<Layout title={`系列：${seriesName} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <PostExplorer
    {page}
    pageTitle={`系列：${seriesName}`}
    pageDesc={`这里收录 ${seriesName} 系列下的文章。`}
    {categories}
    {series}
    {types}
    activeKind="series"
    activeSlug={Astro.params.series}
  />

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
