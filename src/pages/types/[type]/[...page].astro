---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import PostExplorer from "@/components/PostExplorer.astro";
import Footer from "@/components/Footer.astro";
import Pagination from "@/components/Pagination.astro";
import {
  getCategoryItems,
  getPostsByTaxonomy,
  getSeriesItems,
  getTypeItems,
} from "@/utils/taxonomy";
import config from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const typeItems = getTypeItems(posts);

  return typeItems.flatMap(type => {
    const typePosts = getPostsByTaxonomy(posts, "type", type.slug);

    return paginate(typePosts, {
      params: { type: type.slug },
      props: { typeName: type.name },
      pageSize: config.posts.perPage,
    });
  });
}

const { page, typeName } = Astro.props;
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const categories = getCategoryItems(allPosts);
const series = getSeriesItems(allPosts);
const types = getTypeItems(allPosts);
---

<Layout title={`形态：${typeName} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <main id="main-content" class="pb-8">
  <PostExplorer
    {page}
    pageTitle={`形态：${typeName}`}
    pageDesc={`这里收录 ${typeName} 形态的文章。`}
    {categories}
    {series}
    {types}
    activeKind="type"
    activeSlug={Astro.params.type}
  />

  <Pagination {page} />
  </main>

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
