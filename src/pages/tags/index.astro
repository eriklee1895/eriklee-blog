---
import Layout from "@/layouts/Layout.astro";
import { getAllPosts, getAllTags } from "@/lib/posts";
import { slugify } from "@/lib/utils";

const posts = await getAllPosts();
const tags = getAllTags(posts);
---

<Layout title="标签" description="按标签浏览文章。">
  <div class="container-wide py-10 sm:py-14">
    <div class="mb-8 border-b border-[var(--border)] pb-6">
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">标签</h1>
      <p class="mt-2 text-[var(--fg-muted)]">{tags.length} 个标签</p>
    </div>
    <div class="flex flex-wrap gap-2">
      {tags.map(({ tag, count }) => (
        <a
          href={`/tags/${slugify(tag)}/`}
          class="inline-flex items-center gap-1.5 rounded-full border border-[var(--border)] bg-[var(--bg-subtle)] px-3 py-1.5 text-sm transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]"
        >
          <span>#{tag}</span>
          <span class="text-xs text-[var(--fg-subtle)]">{count}</span>
        </a>
      ))}
    </div>
  </div>
</Layout>
