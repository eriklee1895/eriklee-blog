---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import TaxonomySidebar from "@/components/TaxonomySidebar.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import { getUniqueTags } from "@/utils/getUniqueTags";
import {
  getCategoryItems,
  getSeriesItems,
  getTypeItems,
} from "@/utils/taxonomy";
import { useTranslations } from "@/i18n";
import config from "@/config";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const tags = getUniqueTags(posts);
const categories = getCategoryItems(posts);
const series = getSeriesItems(posts);
const types = getTypeItems(posts);

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<Layout title={`${t.pages.tagsTitle} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <main
    id="main-content"
    class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-8 px-4 pb-8 lg:grid-cols-[17rem_minmax(0,1fr)]"
  >
    <TaxonomySidebar {categories} {series} {types} activeKind="all" />

    <section class="min-w-0">
      <div class="border-border border-b pb-6">
        <p class="text-muted-foreground mb-3 text-sm font-semibold">
          {t.nav.tags}
        </p>
        <h1 class="text-3xl leading-tight font-semibold sm:text-5xl">
          {t.pages.tagsTitle}
        </h1>
        <p class="text-muted-foreground mt-4 max-w-2xl leading-7">
          {t.pages.tagsDesc}
        </p>
      </div>

      <ul class="mt-6 flex flex-wrap gap-3">
        {tags.map(({ tag, tagName }) => <Tag {tag} {tagName} />)}
      </ul>
    </section>
  </main>

  <Footer />
</Layout>
