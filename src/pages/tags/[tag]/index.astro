---
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import { getAllPosts } from "@/lib/posts";
import { slugify } from "@/lib/utils";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  const tagMap = new Map<string, { name: string; posts: typeof posts }>();
  for (const post of posts) {
    for (const rawTag of post.data.tags) {
      const slug = slugify(rawTag);
      if (!tagMap.has(slug)) {
        tagMap.set(slug, { name: rawTag, posts: [] });
      }
      tagMap.get(slug)!.posts.push(post);
    }
  }
  return Array.from(tagMap.entries()).map(([slug, { name, posts: tagPosts }]) => ({
    params: { tag: slug },
    props: { posts: tagPosts, tagName: name },
  }));
}

interface Props {
  posts: Awaited<ReturnType<typeof getAllPosts>>;
  tagName: string;
}

const { posts, tagName } = Astro.props;
---

<Layout title={`标签：${tagName}`} description={`所有标记为 ${tagName} 的文章。`}>
  <div class="container-wide py-10 sm:py-14">
    <div class="mb-8 border-b border-[var(--border)] pb-6">
      <a href="/tags" class="text-sm text-[var(--fg-subtle)] hover:text-[var(--accent)]">← 所有标签</a>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">#{tagName}</h1>
      <p class="mt-2 text-[var(--fg-muted)]">{posts.length} 篇</p>
    </div>
    <div class="max-w-3xl">
      {posts.map(p => <PostCard post={p} />)}
    </div>
  </div>
</Layout>
