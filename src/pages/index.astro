---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PostExplorer from "@/components/PostExplorer.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import {
  getCategoryItems,
  getSeriesItems,
  getTypeItems,
} from "@/utils/taxonomy";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(allPosts);
const recentPosts = sortedPosts.slice(0, config.posts.perIndex);
const categories = getCategoryItems(allPosts);
const series = getSeriesItems(allPosts);
const types = getTypeItems(allPosts);
const homePath = getRelativeLocaleUrl(locale, "");
const postsPath = getRelativeLocaleUrl(locale, "posts");
---

<Layout>
  <Header />

  <PostExplorer
    posts={recentPosts}
    pageTitle="用模型搭系统时，我写下的现场笔记。"
    pageDesc="这里记录我对 AI 工程、Agent 架构、编程工具和产品化 workflow 的长期观察：从源码阅读、框架拆解，到把模型接进真实软件的那些细节。"
    eyebrow="AI 工程 / Agent 系统 / 工具链"
    {categories}
    {series}
    {types}
    activeKind="all"
    actionHref={postsPath}
    actionLabel={`查看全部 ${sortedPosts.length} 篇`}
  />

  <Footer />
</Layout>

<script is:inline define:vars={{ homePath }}>
  document.addEventListener("astro:page-load", () => {
    sessionStorage.setItem("backUrl", homePath);
  });
</script>
