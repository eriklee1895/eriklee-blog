---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import PostExplorer from "@/components/PostExplorer.astro";
import Footer from "@/components/Footer.astro";
import Pagination from "@/components/Pagination.astro";
import {
  getCategoryItems,
  getPostsByTaxonomy,
  getSeriesItems,
} from "@/utils/taxonomy";
import config from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const categories = getCategoryItems(posts);

  return categories.flatMap(category => {
    const categoryPosts = getPostsByTaxonomy(posts, "category", category.slug);

    return paginate(categoryPosts, {
      params: { category: category.slug },
      props: { categoryName: category.name },
      pageSize: config.posts.perPage,
    });
  });
}

const { page, categoryName } = Astro.props;
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const categories = getCategoryItems(allPosts);
const series = getSeriesItems(allPosts);
---

<Layout title={`分类：${categoryName} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <PostExplorer
    {page}
    pageTitle={`分类：${categoryName}`}
    pageDesc={`这里收录 ${categoryName} 分类下的文章。`}
    {categories}
    {series}
    activeKind="category"
    activeSlug={Astro.params.category}
  />

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
