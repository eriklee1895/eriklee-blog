---
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import Sidebar from "@/components/Sidebar.astro";
import { getAllPosts, getCategories, getSeries } from "@/lib/posts";
import { taxonomyLabel, slugify } from "@/lib/utils";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  const categories = getCategories(posts);
  return categories.map(cat => ({
    params: { category: cat.slug },
    props: { posts: cat.posts, categoryName: cat.name, categories, series: getSeries(posts) },
  }));
}

const { posts, categoryName, categories, series } = Astro.props;
---

<Layout title={`分类：${categoryName}`} description={`${categoryName} 分类下的所有文章。`}>
  <div class="container-wide py-10 sm:py-14 lg:grid lg:grid-cols-[1fr_14rem] lg:gap-12">
    <div>
      <div class="mb-8 border-b border-[var(--border)] pb-6">
        <a href="/" class="text-sm text-[var(--fg-subtle)] hover:text-[var(--accent)]">← 返回</a>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">{categoryName}</h1>
        <p class="mt-2 text-[var(--fg-muted)]">{posts.length} 篇</p>
      </div>
      {posts.map(p => <PostCard post={p} />)}
    </div>
    <Sidebar {categories} {series} activeKind="category" activeSlug={slugify(categoryName)} />
  </div>
</Layout>
