---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Icon from "@/components/icons/Icon.astro";
import { getAllPosts, getPostUrl, getPostSlug, getPostsBySeries } from "@/lib/posts";
import { formatDate, formatReadingTime, getReadingTime, taxonomyLabel, slugify } from "@/lib/utils";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map(post => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDatetime, modDatetime, category, series, tags } = post.data;
const readingMinutes = getReadingTime(post.body ?? "");
const readingLabel = formatReadingTime(readingMinutes);
const dateLabel = formatDate(pubDatetime);
const catLabel = taxonomyLabel("category", category ?? "其他");
const catSlug = slugify(category ?? "其他");
const seriesSlug = series ? slugify(series) : null;
const seriesLabel = series ? taxonomyLabel("series", series) : null;
const seriesPosts = series ? getPostsBySeries(await getAllPosts(), seriesSlug!).sort((a, b) => a.data.pubDatetime.getTime() - b.data.pubDatetime.getTime()) : [];
const seriesIndex = seriesPosts.findIndex(p => p.id === post.id);
const prevInSeries = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : null;
const nextInSeries = seriesIndex < seriesPosts.length - 1 ? seriesPosts[seriesIndex + 1] : null;
---

<Layout title={title} description={description}>
  <article class="pb-16">
    {/* Article header */}
    <header class="border-b border-[var(--border)] pt-10 pb-8 sm:pt-16">
      <div class="container-prose">
        <div class="mb-4 flex items-center gap-2 text-xs">
          <a href={`/categories/${catSlug}/`} class="rounded-full bg-[var(--bg-subtle)] px-2.5 py-0.5 font-medium text-[var(--fg-muted)] hover:text-[var(--accent)] transition-colors">{catLabel}</a>
          {series && <a href={`/series/${seriesSlug}/`} class="rounded-full border border-[var(--border)] px-2.5 py-0.5 text-[var(--fg-subtle)] hover:text-[var(--accent)] hover:border-[var(--accent)] transition-colors">{seriesLabel}</a>}
        </div>
        <h1 class="text-3xl font-semibold leading-tight tracking-tight sm:text-[2.5rem] sm:leading-[1.2]">{title}</h1>
        <p class="mt-4 text-lg leading-relaxed text-[var(--fg-muted)]">{description}</p>
        <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-[var(--fg-subtle)]">
          <span class="inline-flex items-center gap-1"><Icon name="calendar" size={14} /> {dateLabel}</span>
          {modDatetime && modDatetime > pubDatetime && (
            <span>（更新于 {formatDate(modDatetime)}）</span>
          )}
          <span>·</span>
          <span class="inline-flex items-center gap-1"><Icon name="clock" size={14} /> {readingLabel}</span>
        </div>
      </div>
    </header>

    {/* Article body + TOC */}
    <div class="container-wide pt-10 lg:grid lg:grid-cols-[1fr_14rem] lg:gap-12">
      <div>
        <div class="prose mx-auto max-w-none" data-pagefind-body>
          <Content />
        </div>

        {/* Tags */}
        {tags.length > 0 && (
          <div class="mx-auto mt-12 max-w-none">
            <div class="flex flex-wrap gap-2 border-t border-[var(--border-subtle)] pt-6">
              {tags.map(tag => (
                <a href={`/tags/${slugify(tag)}/`} class="inline-flex items-center gap-1 rounded-full border border-[var(--border)] px-2.5 py-1 text-xs text-[var(--fg-muted)] transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]">
                  <Icon name="hash" size={12} />{tag}
                </a>
              ))}
            </div>
          </div>
        )}

        {/* Series navigation */}
        {series && seriesPosts.length > 1 && (
          <div class="mx-auto mt-10 max-w-none rounded-lg border border-[var(--border)] bg-[var(--bg-subtle)] p-5">
            <h2 class="mb-3 text-sm font-semibold">系列文章：{seriesLabel}</h2>
            <ol class="space-y-1.5 text-sm">
              {seriesPosts.map((p, i) => {
                const isCurrent = p.id === post.id;
                return (
                  <li class="flex items-start gap-2">
                    <span class:list={["mt-0.5 w-5 flex-none text-xs text-[var(--fg-subtle)]", isCurrent && "text-[var(--accent)] font-semibold"]}>{i + 1}.</span>
                    {isCurrent ? (
                      <span class="font-medium">{p.data.title}</span>
                    ) : (
                      <a href={getPostUrl(p)} class="text-[var(--fg-muted)] hover:text-[var(--accent)]">{p.data.title}</a>
                    )}
                  </li>
                );
              })}
            </ol>
            <div class="mt-4 flex justify-between border-t border-[var(--border)] pt-4 text-sm">
              {prevInSeries ? (
                <a href={getPostUrl(prevInSeries)} class="text-[var(--fg-muted)] hover:text-[var(--accent)]">← {prevInSeries.data.title}</a>
              ) : <span />}
              {nextInSeries ? (
                <a href={getPostUrl(nextInSeries)} class="text-[var(--fg-muted)] hover:text-[var(--accent)]">{nextInSeries.data.title} →</a>
              ) : <span />}
            </div>
          </div>
        )}

        {/* Back link */}
        <div class="mx-auto mt-10 max-w-none">
          <a href="/" class="inline-flex items-center gap-1 text-sm text-[var(--fg-subtle)] hover:text-[var(--accent)]">
            <Icon name="arrowLeft" size={14} /> 返回文章列表
          </a>
        </div>
      </div>

      {/* TOC sidebar */}
      <aside class="hidden lg:block">
        <nav id="toc" class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto">
          <p class="mb-3 text-[11px] font-semibold uppercase tracking-wider text-[var(--fg-subtle)]">目录</p>
          <ul id="toc-list" class="space-y-1.5 text-sm"></ul>
        </nav>
      </aside>
    </div>
  </article>
</Layout>

<script is:inline define:vars={{}}>
(function () {
  const article = document.querySelector(".prose");
  const list = document.getElementById("toc-list");
  const toc = document.getElementById("toc");
  if (!article || !list || !toc) return;

  const headings = article.querySelectorAll("h2, h3");
  if (headings.length < 3) {
    toc.style.display = "none";
    return;
  }

  const usedIds = new Set();
  headings.forEach(h => {
    if (!h.id) {
      const base = (h.textContent || "section").trim()
        .toLowerCase()
        .replace(/\s+/g, "-")
        .replace(/[^\w\u4e00-\u9fff-]/g, "")
        .slice(0, 40);
      let id = base || "section";
      let n = 1;
      while (usedIds.has(id)) id = `${base}-${n++}`;
      usedIds.add(id);
      h.id = id;
    } else {
      usedIds.add(h.id);
    }

    const li = document.createElement("li");
    const a = document.createElement("a");
    a.href = `#${h.id}`;
    a.textContent = h.textContent || "";
    a.dataset.target = h.id;
    a.className = "block text-[var(--fg-subtle)] hover:text-[var(--accent)] transition-colors leading-snug " +
      (h.tagName === "H3" ? "pl-3 text-xs border-l border-[var(--border)] ml-0.5" : "");
    li.appendChild(a);
    list.appendChild(li);
  });

  const links = list.querySelectorAll<HTMLAnchorElement>("a[data-target]");
  const linkMap = new Map<string, HTMLAnchorElement>();
  links.forEach(a => linkMap.set(a.dataset.target!, a));

  let activeId: string | null = null;
  function setActive(id: string | null) {
    if (id === activeId) return;
    activeId = id;
    links.forEach(a => {
      if (a.dataset.target === id) {
        a.classList.add("text-[var(--accent)]", "font-medium");
        a.classList.remove("text-[var(--fg-subtle)]");
      } else {
        a.classList.remove("text-[var(--accent)]", "font-medium");
        a.classList.add("text-[var(--fg-subtle)]");
      }
    });
  }

  const observer = new IntersectionObserver(entries => {
    const visible = entries.filter(e => e.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
    if (visible.length) setActive(visible[0].target.id);
  }, { rootMargin: "-80px 0px -70% 0px", threshold: 0 });

  headings.forEach(h => observer.observe(h));

  list.addEventListener("click", e => {
    const a = (e.target as HTMLElement).closest("a[data-target]") as HTMLAnchorElement | null;
    if (!a) return;
    e.preventDefault();
    const el = document.getElementById(a.dataset.target!);
    if (el) {
      el.scrollIntoView({ behavior: "smooth", block: "start" });
      history.replaceState(null, "", `#${a.dataset.target}`);
    }
  });
})();
</script>

<script is:inline define:vars={{}}>
(function () {
  const article = document.querySelector(".prose");
  if (!article) return;

  let overlay = null;
  let lastFocus = null;

  function close() {
    if (!overlay) return;
    const el = overlay;
    overlay = null;
    document.body.style.overflow = "";
    document.removeEventListener("keydown", onKey);
    el.addEventListener("transitionend", () => el.remove(), { once: true });
    el.classList.remove("opacity-100");
    lastFocus?.focus();
  }

  function onKey(e) {
    if (e.key === "Escape") close();
  }

  article.addEventListener("click", e => {
    const img = e.target.closest("img");
    if (!img || img.closest("a")) return;
    e.preventDefault();

    lastFocus = img;
    overlay = document.createElement("div");
    overlay.setAttribute("role", "dialog");
    overlay.setAttribute("aria-modal", "true");
    overlay.className = "fixed inset-0 z-50 flex items-center justify-center bg-black/80 p-4 opacity-0 transition-opacity cursor-zoom-out";
    overlay.innerHTML = `<img src="${img.currentSrc || img.src}" alt="${img.alt}" class="max-h-full max-w-full rounded-lg" />`;
    document.body.appendChild(overlay);
    document.body.style.overflow = "hidden";
    document.addEventListener("keydown", onKey);
    requestAnimationFrame(() => overlay?.classList.add("opacity-100"));
    overlay.addEventListener("click", close);
  });

  // Back to top
  const btt = document.createElement("button");
  btt.className = "fixed bottom-6 right-6 z-40 flex h-10 w-10 items-center justify-center rounded-full bg-[var(--bg-elevated)] border border-[var(--border)] text-[var(--fg-muted)] shadow-lg opacity-0 pointer-events-none transition-all hover:text-[var(--accent)]";
  btt.setAttribute("aria-label", "回到顶部");
  btt.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>';
  btt.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
  document.body.appendChild(btt);

  window.addEventListener("scroll", () => {
    const visible = window.scrollY > 400;
    btt.style.opacity = visible ? "1" : "0";
    btt.style.pointerEvents = visible ? "auto" : "none";
  }, { passive: true });

  document.addEventListener("astro:before-swap", close);
})();
</script>
