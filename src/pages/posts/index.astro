---
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import Sidebar from "@/components/Sidebar.astro";
import { getAllPosts, getCategories, getSeries } from "@/lib/posts";

const posts = await getAllPosts();
const categories = getCategories(posts);
const series = getSeries(posts);
---

<Layout title="文章" description="所有文章列表。">
  <div class="container-wide py-10 sm:py-14 lg:grid lg:grid-cols-[1fr_14rem] lg:gap-12">
    <div>
      <div class="mb-8 border-b border-[var(--border)] pb-6">
        <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">全部文章</h1>
        <p class="mt-2 text-[var(--fg-muted)]">{posts.length} 篇</p>
      </div>
      {posts.map(p => <PostCard post={p} />)}
    </div>
    <Sidebar {categories} {series} activeKind="all" />
  </div>
</Layout>
