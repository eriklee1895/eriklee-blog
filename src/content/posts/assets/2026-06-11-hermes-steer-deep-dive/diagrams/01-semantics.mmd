flowchart TD
    U["运行中,用户补一句话"] --> Q{"哪种语义?"}
    Q -->|"/stop"| I["Interrupt 硬中断"]
    Q -->|"普通排队输入"| QU["Queue 排队"]
    Q -->|"/steer"| S["Steer 中途引导"]

    I --> I1["打断当前工具调用"]
    I1 --> I2["丢弃本轮进展"]
    I2 --> I3["丢弃待发的 steer"]

    QU --> QU1["不打断当前工具"]
    QU1 --> QU2["存入待处理输入"]
    QU2 --> QU3["等回合结束<br/>作为下一轮 user 消息"]

    S --> S1["不打断当前工具"]
    S1 --> S2["保留全部上下文"]
    S2 --> S3["挂到最近工具结果尾部"]
    S3 --> S4["模型下一次迭代即看到"]
