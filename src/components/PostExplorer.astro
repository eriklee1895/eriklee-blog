---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import Card from "@/components/Card.astro";
import TaxonomySidebar from "@/components/TaxonomySidebar.astro";
import type { TaxonomyItem } from "@/utils/taxonomy";

type Props = {
  page: Page<CollectionEntry<"posts">>;
  pageTitle: string;
  pageDesc?: string;
  categories: TaxonomyItem[];
  series: TaxonomyItem[];
  activeKind?: "all" | "category" | "series";
  activeSlug?: string;
};

const {
  page,
  pageTitle,
  pageDesc,
  categories,
  series,
  activeKind = "all",
  activeSlug,
} = Astro.props;
---

<main
  id="main-content"
  class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-8 px-4 pb-8 lg:grid-cols-[16rem_minmax(0,1fr)]"
>
  <TaxonomySidebar
    {categories}
    {series}
    {activeKind}
    {activeSlug}
  />

  <section class="min-w-0">
    <div class="border-border border-b pb-6">
      <p class="text-muted-foreground mb-3 text-sm font-semibold tracking-[0.18em] uppercase">
        Erik Lee / Blog
      </p>
      <h1 class="text-2xl font-semibold sm:text-4xl">{pageTitle}</h1>
      {pageDesc && <p class="text-muted-foreground mt-3 max-w-2xl leading-7">{pageDesc}</p>}
    </div>

    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </section>
</main>
