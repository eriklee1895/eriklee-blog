---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import TaxonomySidebar from "@/components/TaxonomySidebar.astro";
import type { TaxonomyItem } from "@/utils/taxonomy";

type Props = {
  page?: Page<CollectionEntry<"posts">>;
  posts?: CollectionEntry<"posts">[];
  pageTitle: string;
  pageDesc?: string;
  eyebrow?: string;
  categories: TaxonomyItem[];
  series: TaxonomyItem[];
  types?: TaxonomyItem[];
  activeKind?: "all" | "category" | "series" | "type";
  activeSlug?: string;
  actionHref?: string;
  actionLabel?: string;
};

const {
  page,
  posts,
  pageTitle,
  pageDesc,
  eyebrow = "Erik Lee / Blog",
  categories,
  series,
  types = [],
  activeKind = "all",
  activeSlug,
  actionHref,
  actionLabel,
} = Astro.props;

const items = page?.data ?? posts ?? [];
---

<main
  id="main-content"
  class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-8 px-4 pb-8 lg:grid-cols-[17rem_minmax(0,1fr)]"
>
  <TaxonomySidebar {categories} {series} {types} {activeKind} {activeSlug} />

  <section class="min-w-0">
    <div class="border-border border-b pb-6 sm:flex sm:items-end sm:justify-between sm:gap-6">
      <div>
        <p class="text-muted-foreground mb-3 text-sm font-semibold">
          {eyebrow}
        </p>
        <h1 class="max-w-3xl text-3xl leading-tight font-semibold sm:text-5xl">
          {pageTitle}
        </h1>
        {
          pageDesc && (
            <p class="text-muted-foreground mt-4 max-w-2xl leading-7">
              {pageDesc}
            </p>
          )
        }
      </div>
      {
        actionHref && actionLabel && (
          <LinkButton
            href={actionHref}
            class="mt-5 shrink-0 sm:mt-0"
          >
            {actionLabel}
          </LinkButton>
        )
      }
    </div>

    <ul class="divide-border divide-y">
      {items.map(data => <Card {...data} />)}
    </ul>
  </section>
</main>
