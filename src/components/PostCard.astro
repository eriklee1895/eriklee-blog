---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/lib/posts";
import { formatDate, formatReadingTime, getReadingTime, taxonomyLabel, slugify } from "@/lib/utils";
import Icon from "@/components/icons/Icon.astro";

interface Props {
  post: CollectionEntry<"posts">;
  variant?: "default" | "featured" | "compact";
}

const { post, variant = "default" } = Astro.props;
const { title, description, pubDatetime, category, series } = post.data;
const url = getPostUrl(post);
const readingMinutes = getReadingTime(post.body ?? "");
const readingLabel = formatReadingTime(readingMinutes);
const dateLabel = formatDate(pubDatetime);
const catLabel = taxonomyLabel("category", category ?? "其他");
---

{
  variant === "featured" ? (
    <article class="group border-b border-[var(--border)] pb-10 mb-10">
      <div class="flex items-center gap-2 mb-4 text-xs">
        <span class="rounded-full bg-[var(--accent)] px-2.5 py-0.5 font-medium text-[var(--accent-contrast)]">精选</span>
        <a href={`/categories/${slugify(category ?? "其他")}/`} class="rounded-full bg-[var(--bg-subtle)] px-2.5 py-0.5 font-medium text-[var(--fg-muted)] hover:text-[var(--accent)] transition-colors">{catLabel}</a>
      </div>
      <a href={url} class="block">
        <h2 class="text-2xl leading-tight font-semibold tracking-tight group-hover:text-[var(--accent)] transition-colors sm:text-3xl">{title}</h2>
      </a>
      <p class="mt-3 text-[15px] leading-relaxed text-[var(--fg-muted)]">{description}</p>
      <div class="mt-4 flex items-center gap-3 text-xs text-[var(--fg-subtle)]">
        <span class="inline-flex items-center gap-1"><Icon name="calendar" size={13} /> {dateLabel}</span>
        <span>·</span>
        <span class="inline-flex items-center gap-1"><Icon name="clock" size={13} /> {readingLabel}</span>
      </div>
    </article>
  ) : variant === "compact" ? (
    <article class="group py-4">
      <a href={url} class="block">
        <h3 class="text-base font-medium leading-snug group-hover:text-[var(--accent)] transition-colors">{title}</h3>
      </a>
      <div class="mt-1 flex items-center gap-2 text-xs text-[var(--fg-subtle)]">
        <time>{dateLabel}</time>
      </div>
    </article>
  ) : (
    <article class="group border-b border-[var(--border-subtle)] py-7 first:pt-0">
      <div class="mb-2 flex items-center gap-2 text-xs">
        <a href={`/categories/${slugify(category ?? "其他")}/`} class="text-[var(--fg-muted)] font-medium hover:text-[var(--accent)] transition-colors">{catLabel}</a>
        {series && (
          <>
            <span class="text-[var(--border)]">·</span>
            <a href={`/series/${slugify(series)}/`} class="text-[var(--fg-subtle)] hover:text-[var(--accent)] transition-colors">{taxonomyLabel("series", series)}</a>
          </>
        )}
      </div>
      <a href={url} class="block">
        <h2 class="text-xl font-semibold leading-snug tracking-tight group-hover:text-[var(--accent)] transition-colors sm:text-[1.375rem]">{title}</h2>
      </a>
      <p class="mt-2 text-[15px] leading-relaxed text-[var(--fg-muted)] line-clamp-2">{description}</p>
      <div class="mt-3 flex items-center gap-3 text-xs text-[var(--fg-subtle)]">
        <time>{dateLabel}</time>
        <span>·</span>
        <span>{readingLabel}</span>
      </div>
    </article>
  )
}
